{
  "name": "paycryptoone/paycrypto-payouts-php-client",
  "description": "PHP client for PayCrypto payouts API v1",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/PayCryptoOne/paycrypto-payouts-php-client",
  "support": {
    "issues": "https://github.com/PayCryptoOne/paycrypto-payouts-php-client/issues",
    "source": "https://github.com/PayCryptoOne/paycrypto-payouts-php-client"
  },
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.8"
  },
  "authors": [
    {
      "name": "PayCryptoOne"
    }
  ],
  "keywords": [
    "paycrypto",
    "payouts",
    "crypto"
  ],
  "autoload": {
    "psr-4": {
      "PayCrypto\\Payouts\\Client\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PayCrypto\\Payouts\\Client\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit",
    "test:live": "php scripts/live-api.php",
    "smoke": "php scripts/smoke.php",
    "e2e": "php scripts/e2e.php"
  }
}
